# CoopVotes Secure Voting System Environment Variables

# Server Configuration
NODE_ENV=production
PORT=5000
FRONTEND_URL=http://localhost:5173

# Database
MONGODB_URI=mongodb://localhost:27017/coopvotes

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long
JWT_EXPIRE=7d

# Cookie Security
COOKIE_SECRET=your-cookie-secret-min-32-characters

# Vote Encryption (AES-256-GCM)
# Generate a secure key using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VOTE_ENCRYPTION_KEY=your-64-character-hex-encryption-key-here

# Admin Configuration
ADMIN_EMAIL=admin@student.cuk.ac.ke
ADMIN_REG_NUMBER=ADMIN/0000/0000

# Security Settings
# Set to 'true' in production
FORCE_HTTPS=false
SECURE_COOKIES=false

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
VOTE_RATE_LIMIT_MAX=10

# Audit Log Settings
AUDIT_LOG_RETENTION_DAYS=90
